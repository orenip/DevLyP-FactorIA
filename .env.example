# FactorIA — Variables de entorno
# Copia este archivo como .env y rellena los valores
# NUNCA subas .env a git

# ================================
# APP
# ================================
APP_NAME=factoria-project
APP_ENV=development          # development | staging | production
APP_PORT=3000
APP_SECRET_KEY=change-this-secret-key-in-production
DEBUG=true

# ================================
# BASE DE DATOS
# ================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=factoria_db
DB_USER=factoria_user
DB_PASSWORD=change-this-password
DB_SSL=false

# URL de conexión (alternativa a los campos individuales)
DATABASE_URL=postgresql://factoria_user:change-this-password@localhost:5432/factoria_db

# ================================
# CACHE / REDIS
# ================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# ================================
# AUTENTICACIÓN
# ================================
JWT_SECRET=change-this-jwt-secret
JWT_EXPIRY=7d
REFRESH_TOKEN_EXPIRY=30d

# OAuth (opcional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ================================
# APIS EXTERNAS
# ================================
# Anthropic
ANTHROPIC_API_KEY=

# OpenAI (si aplica)
OPENAI_API_KEY=

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@tudominio.com

# Storage (S3 / R2 / Supabase Storage)
STORAGE_PROVIDER=s3       # s3 | r2 | supabase | local
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_ENDPOINT=         # para R2 o Supabase

# Stripe (si aplica)
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ================================
# FRONTEND
# ================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=

# ================================
# DEPLOYMENT
# ================================
DOCKER_REGISTRY=
IMAGE_TAG=latest

# ================================
# MONITORING (opcional)
# ================================
SENTRY_DSN=
LOG_LEVEL=info            # debug | info | warn | error
